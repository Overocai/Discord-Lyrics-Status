<UserControl x:Class="DiscordLyrics.Views.LyricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:LyricsViewModel}" mc:Ignorable="d">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding TrackTitle}" Style="{StaticResource Text.Display}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding TrackArtist}" Style="{StaticResource Text.Body}" Margin="0,2,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,22,0,0" Padding="40">
            <Grid>
                <!-- Empty state -->
                <TextBlock Text="{Binding EmptyHint}" Style="{StaticResource Text.Body}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasLyrics, Converter={StaticResource InverseBoolToVis}}" />

                <!-- Karaoke -->
                <StackPanel VerticalAlignment="Center"
                            Visibility="{Binding HasLyrics, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding PrevLine}" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="18" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,18" />
                    <TextBlock Text="{Binding CurrentLine}" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="34" FontWeight="Bold" Foreground="{StaticResource Brush.Red}" />
                    <TextBlock Text="{Binding NextLine}" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="18" Foreground="{StaticResource Brush.TextMuted}" Margin="0,18,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
