<UserControl x:Class="DiscordLyrics.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}" mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="680" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource Text.Display}" />
            <TextBlock Text="Tune how the status engine behaves" Style="{StaticResource Text.Body}" Margin="0,2,0,22" />

            <!-- Status -->
            <Border Style="{StaticResource Card}" Padding="24">
                <StackPanel>
                    <TextBlock Text="STATUS" Style="{StaticResource Text.SectionLabel}" Margin="0,0,0,14" />

                    <TextBlock Text="Status prefix" Style="{StaticResource Text.Body}"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBox Style="{StaticResource Input}" Margin="0,6,0,16" Width="220" HorizontalAlignment="Left"
                             Text="{Binding StatusPrefix, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Emoji name (optional)" Style="{StaticResource Text.Body}"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBox Style="{StaticResource Input}" Margin="0,6,0,16" Width="220" HorizontalAlignment="Left"
                             Text="{Binding EmojiName, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Poll interval (s)" Style="{StaticResource Text.Body}"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBox Style="{StaticResource Input}" Margin="0,6,0,0"
                                     Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Line lead (s)" Style="{StaticResource Text.Body}"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBox Style="{StaticResource Input}" Margin="0,6,0,0"
                                     Text="{Binding LineLeadSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max length" Style="{StaticResource Text.Body}"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBox Style="{StaticResource Input}" Margin="0,6,0,0"
                                     Text="{Binding MaxStatusLength, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Behaviour -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="BEHAVIOUR" Style="{StaticResource Text.SectionLabel}" Margin="0,0,0,8" />

                    <Grid Margin="0,12,0,0">
                        <TextBlock Text="Show song title when no lyrics" Style="{StaticResource Text.Body}"
                                   Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center" />
                        <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                  IsChecked="{Binding ShowSongWhenNoLyrics}" />
                    </Grid>
                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Clear status when paused" Style="{StaticResource Text.Body}"
                                   Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center" />
                        <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                  IsChecked="{Binding ClearOnPause}" />
                    </Grid>
                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Only use time-synced lyrics" Style="{StaticResource Text.Body}"
                                   Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center" />
                        <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                  IsChecked="{Binding SyncedOnly}" />
                    </Grid>
                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Start engine automatically on launch" Style="{StaticResource Text.Body}"
                                   Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center" />
                        <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                  IsChecked="{Binding AutoStartEngine}" />
                    </Grid>
                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Launch at Windows startup" Style="{StaticResource Text.Body}"
                                   Foreground="{StaticResource Brush.TextPrimary}" VerticalAlignment="Center" />
                        <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                  IsChecked="{Binding LaunchAtStartup}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Button Style="{StaticResource Button.Primary}" Width="180" HorizontalAlignment="Left"
                    Margin="0,20,0,0" Content="Save changes" Command="{Binding SaveCommand}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
