<UserControl x:Class="DiscordLyrics.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,8,28,28">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource Text.Display}" />
                    <TextBlock Text="Your live now-playing overview" Style="{StaticResource Text.Body}" Margin="0,2,0,0" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource Button.Primary}" Width="130"
                        Content="{Binding ToggleLabel}" Command="{Binding ToggleEngineCommand}" />
            </Grid>

            <!-- Top row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <!-- Now playing -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Album art -->
                        <Grid Width="120" Height="120">
                            <Border CornerRadius="14" Background="{StaticResource Brush.SurfaceGradient}">
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                           Foreground="{StaticResource Brush.RedDark}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="14" ClipToBounds="True">
                                <Image Source="{Binding Art}" Stretch="UniformToFill" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="20,4,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TrackTitle}" Style="{StaticResource Text.Title}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding TrackArtist}" Style="{StaticResource Text.Body}"
                                       Margin="0,2,0,14" TextTrimming="CharacterEllipsis" />
                            <ProgressBar Style="{StaticResource Progress}" Minimum="0" Maximum="1"
                                         Value="{Binding Progress}" />
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="{Binding PositionText}" Style="{StaticResource Text.Caption}" />
                                <TextBlock Text="{Binding DurationText}" Style="{StaticResource Text.Caption}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right column -->
                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Card}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="DISCORD" Style="{StaticResource Text.SectionLabel}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Graphite}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Connected}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Brush.Success}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding AccountName}" Margin="9,0,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="18" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="CURRENT STATUS" Style="{StaticResource Text.SectionLabel}" />
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Body}"
                                       Foreground="{StaticResource Brush.TextPrimary}" Margin="0,8,0,0"
                                       MinHeight="34" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Lyrics -->
            <Border Style="{StaticResource Card}" Margin="0,18,0,0" Padding="26">
                <StackPanel>
                    <TextBlock Text="LYRICS" Style="{StaticResource Text.SectionLabel}" />
                    <TextBlock Text="{Binding PrevLine}" Style="{StaticResource Text.Body}"
                               TextAlignment="Center" Margin="0,14,0,0" Opacity="0.5" />
                    <TextBlock Text="{Binding CurrentLine}" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="24" FontWeight="Bold" Margin="0,8"
                               Foreground="{StaticResource Brush.Red}" />
                    <TextBlock Text="{Binding NextLine}" Style="{StaticResource Text.Body}"
                               TextAlignment="Center" Opacity="0.5" />
                </StackPanel>
            </Border>

            <!-- Footer stat -->
            <StackPanel Orientation="Horizontal" Margin="2,16,0,0">
                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           Foreground="{StaticResource Brush.TextMuted}" VerticalAlignment="Center" />
                <TextBlock Margin="8,0,0,0" Style="{StaticResource Text.Caption}">
                    <Run Text="{Binding TracksLogged}" /><Run Text=" tracks logged" />
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
