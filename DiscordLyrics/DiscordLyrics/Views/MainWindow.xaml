<Window x:Class="DiscordLyrics.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
        xmlns:views="clr-namespace:DiscordLyrics.Views"
        Title="Discord Lyrics" Height="720" Width="1120"
        MinHeight="560" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" Background="{StaticResource Brush.Black}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        FontFamily="{StaticResource Font.Text}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LyricsViewModel}"><views:LyricsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiscordViewModel}"><views:DiscordView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfilesViewModel}"><views:ProfilesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}"><views:HistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}"><views:LogsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}"><views:AboutView /></DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================= SIDEBAR ================= -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Sidebar}">
                <DockPanel>
                    <!-- Brand -->
                    <Border DockPanel.Dock="Top" Height="78" Padding="22,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="9"
                                    Background="{StaticResource Brush.RedGradient}">
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="White" FontSize="17"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="DISCORD LYRICS" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource Brush.TextPrimary}" />
                                <TextBlock Text="STATUS ENGINE" Style="{StaticResource Text.Caption}"
                                           Foreground="{StaticResource Brush.Red}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer status -->
                    <Border DockPanel.Dock="Bottom" Padding="20,16" >
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{StaticResource Brush.Success}" x:Name="StatusDot" />
                                <TextBlock x:Name="FooterText" Text="Idle" Margin="8,0,0,0"
                                           Style="{StaticResource Text.Caption}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation -->
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="MENU" Style="{StaticResource Text.SectionLabel}" Margin="26,4,0,8" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Dashboard"
                                     Tag="&#xE80F;" IsChecked="True"
                                     Command="{Binding NavigateCommand}" CommandParameter="dashboard" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Lyrics"
                                     Tag="&#xE8D6;"
                                     Command="{Binding NavigateCommand}" CommandParameter="lyrics" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Discord"
                                     Tag="&#xE8F2;"
                                     Command="{Binding NavigateCommand}" CommandParameter="discord" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Profiles"
                                     Tag="&#xE77B;"
                                     Command="{Binding NavigateCommand}" CommandParameter="profiles" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="History"
                                     Tag="&#xE81C;"
                                     Command="{Binding NavigateCommand}" CommandParameter="history" />
                        <TextBlock Text="SYSTEM" Style="{StaticResource Text.SectionLabel}" Margin="26,16,0,8" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Settings"
                                     Tag="&#xE713;"
                                     Command="{Binding NavigateCommand}" CommandParameter="settings" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="Logs"
                                     Tag="&#xE7C3;"
                                     Command="{Binding NavigateCommand}" CommandParameter="logs" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="About"
                                     Tag="&#xE946;"
                                     Command="{Binding NavigateCommand}" CommandParameter="about" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ================= CONTENT ================= -->
            <Grid Grid.Column="1" Background="{StaticResource Brush.Surface}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0">
                    <TextBlock Text="{Binding ActiveSection}" VerticalAlignment="Center" Margin="24,0"
                               Style="{StaticResource Text.Caption}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinButton" Style="{StaticResource Button.Caption}"
                                Content="&#xE921;" Click="OnMinimize" />
                        <Button x:Name="MaxButton" Style="{StaticResource Button.Caption}"
                                Content="&#xE922;" Click="OnMaximizeRestore" />
                        <Button x:Name="CloseButton" Style="{StaticResource Button.Close}"
                                Content="&#xE8BB;" Click="OnClose" />
                    </StackPanel>
                </Grid>

                <!-- Active page -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="0">
                    <ContentControl.Resources>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <Trigger Property="Content" Value="{x:Null}" />
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Resources>
                </ContentControl>

                <!-- Toast host overlay -->
                <StackPanel x:Name="ToastHost" Grid.Row="1" Margin="0,0,24,24"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" />
            </Grid>
        </Grid>
    </Border>
</Window>
