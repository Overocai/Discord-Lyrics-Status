<UserControl x:Class="DiscordLyrics.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:AboutViewModel}" mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="About" Style="{StaticResource Text.Display}" />

            <Border Style="{StaticResource Card}" Padding="28" Margin="0,22,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="56" Height="56" CornerRadius="14" Background="{StaticResource Brush.RedGradient}">
                            <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Discord Lyrics" Style="{StaticResource Text.Title}" />
                            <TextBlock Style="{StaticResource Text.Body}">
                                <Run Text="Version" /><Run Text=" " /><Run Text="{Binding Version}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Margin="0,20,0,0" Style="{StaticResource Text.Body}"
                               Text="A premium desktop app that turns the song you're playing into time-synced lyrics on your Discord custom status." />

                    <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,20" />

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="AUTHOR" Style="{StaticResource Text.SectionLabel}" />
                            <TextBlock Text="{Binding Author}" Margin="0,4,0,0" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource Button.Ghost}" Width="120" Content="GitHub"
                                    Command="{Binding OpenUrlCommand}" CommandParameter="{Binding RepoUrl}" />
                            <Button Style="{StaticResource Button.Ghost}" Width="120" Margin="10,0,0,0" Content="Discord"
                                    Command="{Binding OpenUrlCommand}" CommandParameter="{Binding DiscordUrl}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="24" Margin="0,18,0,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="UPDATES" Style="{StaticResource Text.SectionLabel}" />
                        <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Text.Body}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Style="{StaticResource Button.Primary}" Width="170" HorizontalAlignment="Right"
                            Content="Check for updates" Command="{Binding CheckUpdatesCommand}" />
                </Grid>
            </Border>

            <TextBlock Margin="2,18,0,0" Style="{StaticResource Text.Caption}"
                       Text="For educational use only. Automating a user account may violate Discord's Terms of Service." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
