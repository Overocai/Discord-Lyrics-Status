<UserControl x:Class="DiscordLyrics.Views.DiscordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:DiscordViewModel}" mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Discord" Style="{StaticResource Text.Display}" />
            <TextBlock Text="Connect your account to drive the custom status"
                       Style="{StaticResource Text.Body}" Margin="0,2,0,22" />

            <!-- Connection status -->
            <Border Style="{StaticResource Card}" Padding="22">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="11" Height="11" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Brush.Graphite}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Connected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Success}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="{Binding AccountName}" FontWeight="SemiBold" FontSize="15"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBlock Text="{Binding AccountId}" Style="{StaticResource Text.Caption}"
                                       Visibility="{Binding AccountId, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Style="{StaticResource Button.Ghost}" Width="120"
                            Content="Disconnect" Command="{Binding DisconnectCommand}"
                            Visibility="{Binding HasStoredToken, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>

            <!-- Token entry -->
            <Border Style="{StaticResource Card}" Padding="22" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="DISCORD TOKEN" Style="{StaticResource Text.SectionLabel}" />
                    <Border Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="10"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            Height="42" Margin="0,10,0,0">
                        <PasswordBox x:Name="TokenBox" PasswordChanged="OnPasswordChanged"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Brush.TextPrimary}"
                                     CaretBrush="{StaticResource Brush.Red}"
                                     VerticalContentAlignment="Center" Padding="12,0" FontSize="13" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Style="{StaticResource Button.Primary}" Width="160"
                                Content="Connect" Command="{Binding ConnectCommand}" />
                    </StackPanel>
                    <Border Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="10" Padding="14"
                            Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Foreground="{StaticResource Brush.Red}" VerticalAlignment="Top" />
                            <TextBlock Margin="12,0,0,0" Style="{StaticResource Text.Body}" MaxWidth="520"
                                       Text="Your token is encrypted with Windows DPAPI and stored only on this PC. It is never uploaded anywhere. Using a user token automates your account — for educational use only." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
