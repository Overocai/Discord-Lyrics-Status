<UserControl x:Class="DiscordLyrics.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscordLyrics.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:HistoryViewModel}" mc:Ignorable="d">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="History" Style="{StaticResource Text.Display}" />
                <TextBlock Style="{StaticResource Text.Body}" Margin="0,2,0,0">
                    <Run Text="{Binding Total}" /><Run Text=" tracks detected" />
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource Button.Ghost}" Width="110" Content="Refresh"
                        Command="{Binding RefreshCommand}" />
                <Button Style="{StaticResource Button.Ghost}" Width="100" Margin="10,0,0,0" Content="Clear"
                        Command="{Binding ClearCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <TextBlock Text="Nothing here yet — play a song with the engine running."
                           Style="{StaticResource Text.Body}" HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,12" Margin="2" CornerRadius="8" Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Artist}" Style="{StaticResource Text.Caption}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Padding="8,3" CornerRadius="6" VerticalAlignment="Center"
                                                Background="{StaticResource Brush.RedDark}" Margin="0,0,14,0"
                                                Visibility="{Binding HadLyrics, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="LYRICS" FontSize="9" FontWeight="Bold" Foreground="White" />
                                        </Border>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Text="{Binding PlayedAt, StringFormat='{}{0:dd/MM HH:mm}'}"
                                                   Style="{StaticResource Text.Caption}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
