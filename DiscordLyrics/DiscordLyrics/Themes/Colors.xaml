<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         DISCORD LYRICS — DESIGN SYSTEM / COLOR TOKENS
         Deep black · graphite gray · premium red · dark red accents
         ============================================================ -->

    <!-- Surfaces (darkest -> lightest) -->
    <Color x:Key="Color.Black">#FF07080A</Color>
    <Color x:Key="Color.Sidebar">#FF0D0E12</Color>
    <Color x:Key="Color.Surface">#FF131419</Color>
    <Color x:Key="Color.SurfaceAlt">#FF191B21</Color>
    <Color x:Key="Color.Card">#FF1E2027</Color>
    <Color x:Key="Color.CardHover">#FF24262F</Color>
    <Color x:Key="Color.Border">#FF2A2C35</Color>
    <Color x:Key="Color.Graphite">#FF34363F</Color>

    <!-- Text -->
    <Color x:Key="Color.TextPrimary">#FFF3F4F6</Color>
    <Color x:Key="Color.TextSecondary">#FFA0A3AD</Color>
    <Color x:Key="Color.TextMuted">#FF6A6D78</Color>

    <!-- Brand red -->
    <Color x:Key="Color.Red">#FFE5383B</Color>
    <Color x:Key="Color.RedHover">#FFFF4A4E</Color>
    <Color x:Key="Color.RedPressed">#FFC42B2E</Color>
    <Color x:Key="Color.RedDark">#FF9E1B1F</Color>
    <Color x:Key="Color.RedDeep">#FF6E1215</Color>

    <!-- Semantic -->
    <Color x:Key="Color.Success">#FF3BA55D</Color>
    <Color x:Key="Color.Warning">#FFE0A106</Color>
    <Color x:Key="Color.Danger">#FFE5383B</Color>

    <!-- ============================================================
         BRUSHES
         ============================================================ -->
    <SolidColorBrush x:Key="Brush.Black"        Color="{StaticResource Color.Black}" />
    <SolidColorBrush x:Key="Brush.Sidebar"      Color="{StaticResource Color.Sidebar}" />
    <SolidColorBrush x:Key="Brush.Surface"      Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"   Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Card"         Color="{StaticResource Color.Card}" />
    <SolidColorBrush x:Key="Brush.CardHover"    Color="{StaticResource Color.CardHover}" />
    <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Graphite"     Color="{StaticResource Color.Graphite}" />

    <SolidColorBrush x:Key="Brush.TextPrimary"   Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted"     Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.Red"        Color="{StaticResource Color.Red}" />
    <SolidColorBrush x:Key="Brush.RedHover"   Color="{StaticResource Color.RedHover}" />
    <SolidColorBrush x:Key="Brush.RedPressed" Color="{StaticResource Color.RedPressed}" />
    <SolidColorBrush x:Key="Brush.RedDark"    Color="{StaticResource Color.RedDark}" />

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger"  Color="{StaticResource Color.Danger}" />

    <!-- Signature gradient (premium red, used for accents and the brand mark) -->
    <LinearGradientBrush x:Key="Brush.RedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFF4A4E" Offset="0" />
        <GradientStop Color="#FFE5383B" Offset="0.5" />
        <GradientStop Color="#FF8E171B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.SurfaceGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF15161B" Offset="0" />
        <GradientStop Color="#FF0E0F13" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
