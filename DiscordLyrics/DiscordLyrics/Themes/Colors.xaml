<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         DISCORD LYRICS — DESIGN SYSTEM / COLOR TOKENS
         Discord dark theme: graphite grays + blurple accent
         (Accent keys keep the historical "Red" names so every view
          updates from one place; the values are Discord blurple.)
         ============================================================ -->

    <!-- Surfaces (darkest -> lightest) — Discord dark palette -->
    <Color x:Key="Color.Black">#FF1E1F22</Color>      <!-- window / title bar -->
    <Color x:Key="Color.Sidebar">#FF2B2D31</Color>    <!-- navigation rail -->
    <Color x:Key="Color.Surface">#FF313338</Color>    <!-- content area -->
    <Color x:Key="Color.SurfaceAlt">#FF383A40</Color> <!-- inputs / insets -->
    <Color x:Key="Color.Card">#FF2B2D31</Color>       <!-- cards / panels -->
    <Color x:Key="Color.CardHover">#FF35373C</Color>  <!-- hover -->
    <Color x:Key="Color.Border">#FF3F4147</Color>     <!-- separators -->
    <Color x:Key="Color.Graphite">#FF4E5058</Color>   <!-- disabled / tracks -->

    <!-- Text -->
    <Color x:Key="Color.TextPrimary">#FFF2F3F5</Color>
    <Color x:Key="Color.TextSecondary">#FFB5BAC1</Color>
    <Color x:Key="Color.TextMuted">#FF80848E</Color>

    <!-- Accent — Discord blurple -->
    <Color x:Key="Color.Red">#FF5865F2</Color>
    <Color x:Key="Color.RedHover">#FF4752C4</Color>
    <Color x:Key="Color.RedPressed">#FF3C45A5</Color>
    <Color x:Key="Color.RedDark">#FF4752C4</Color>
    <Color x:Key="Color.RedDeep">#FF3C45A5</Color>

    <!-- Semantic — Discord -->
    <Color x:Key="Color.Success">#FF23A55A</Color>
    <Color x:Key="Color.Warning">#FFF0B232</Color>
    <Color x:Key="Color.Danger">#FFDA373C</Color>

    <!-- ============================================================
         BRUSHES
         ============================================================ -->
    <SolidColorBrush x:Key="Brush.Black"        Color="{StaticResource Color.Black}" />
    <SolidColorBrush x:Key="Brush.Sidebar"      Color="{StaticResource Color.Sidebar}" />
    <SolidColorBrush x:Key="Brush.Surface"      Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"   Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Card"         Color="{StaticResource Color.Card}" />
    <SolidColorBrush x:Key="Brush.CardHover"    Color="{StaticResource Color.CardHover}" />
    <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Graphite"     Color="{StaticResource Color.Graphite}" />

    <SolidColorBrush x:Key="Brush.TextPrimary"   Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted"     Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.Red"        Color="{StaticResource Color.Red}" />
    <SolidColorBrush x:Key="Brush.RedHover"   Color="{StaticResource Color.RedHover}" />
    <SolidColorBrush x:Key="Brush.RedPressed" Color="{StaticResource Color.RedPressed}" />
    <SolidColorBrush x:Key="Brush.RedDark"    Color="{StaticResource Color.RedDark}" />

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger"  Color="{StaticResource Color.Danger}" />

    <!-- Signature gradient (blurple) — brand mark and accents -->
    <LinearGradientBrush x:Key="Brush.RedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF6B73F5" Offset="0" />
        <GradientStop Color="#FF5865F2" Offset="0.5" />
        <GradientStop Color="#FF4752C4" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.SurfaceGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF313338" Offset="0" />
        <GradientStop Color="#FF2B2D31" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
