<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Type scale. Segoe UI Variable ships on Windows 11; we fall back gracefully. -->
    <FontFamily x:Key="Font.Display">Segoe UI Variable Display, Segoe UI, Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="Font.Text">Segoe UI Variable Text, Segoe UI</FontFamily>

    <sys:Double x:Key="Size.Display">28</sys:Double>
    <sys:Double x:Key="Size.Title">20</sys:Double>
    <sys:Double x:Key="Size.Subtitle">15</sys:Double>
    <sys:Double x:Key="Size.Body">13</sys:Double>
    <sys:Double x:Key="Size.Caption">11</sys:Double>

    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Size.Display}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style x:Key="Text.Subtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="{StaticResource Size.Subtitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="{StaticResource Size.Body}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="{StaticResource Size.Caption}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Text.SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Text}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
    </Style>

</ResourceDictionary>
